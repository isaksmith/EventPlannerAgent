# Redis
REDIS_URL=redis://localhost:6379/0

# Poke SMS
POKE_WEBHOOK_SECRET=dev-secret-change-me
POKE_API_KEY=
POKE_API_BASE_URL=https://api.poke.dev/v1

# Arize — real OTel export when enabled (see app/observability/arize.py)
ARIZE_ENABLED=true
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=orchestrateai

# App
APP_ENV=development
LOG_LEVEL=info

# Public HTTPS base (ngrok) — enables live site URLs in SMS after APPROVE
PUBLIC_BASE_URL=https://stegosaur-setting-mammogram.ngrok-free.dev

# Supabase (registration persistence — optional; jsonl fallback when unset)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Build output (local paths for generated sites + assets)
ASSETS_OUTPUT_DIR=var/assets
BUILD_OUTPUT_DIR=var/builds

# Vercel (optional — local file:// URL when unset)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# Browserbase (Devpost automation — disabled by default)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
BROWSERBASE_ENABLED=true
BROWSERBASE_VERIFY_SITE=true
BROWSERBASE_TEST_REGISTRATION=true
BROWSERBASE_VERIFY_SLACK=true
DEVPOST_ENABLED=false

# Slack (pre-created workspace + OAuth token)
SLACK_ACCESS_TOKEN=
SLACK_REFRESH_TOKEN=
SLACK_INVITE_URL=

# Creative APIs (optional — local SVG stubs when Midjourney MCP disabled)
MIDJOURNEY_MCP_ENABLED=false
MIDJOURNEY_MCP_URL=https://mcp.midjourney.com/mcp
MIDJOURNEY_MCP_TOKEN=
MIDJOURNEY_MCP_USE_OAUTH=false
MIDJOURNEY_MCP_TIMEOUT_SECONDS=480
MIDJOURNEY_API_KEY=
PIKA_ENABLED=false
PIKA_API_KEY=
PIKA_MODEL_TEXT=fal-ai/pika/v2.2/text-to-video
PIKA_MODEL_IMAGE=fal-ai/pika/v2.2/image-to-video
PIKA_DURATION_SECONDS=5
PIKA_RESOLUTION=720p
PIKA_ASPECT_RATIO=16:9
PIKA_USE_HERO_IMAGE=true
PIKA_TIMEOUT_SECONDS=300

# OpenRouter — image generation fallback when Midjourney MCP fails
OPENROUTER_API_KEY=
OPENROUTER_IMAGE_ENABLED=true
OPENROUTER_IMAGE_MODEL=google/gemini-3-pro-image
OPENROUTER_IMAGE_TIMEOUT_SECONDS=120
OPENROUTER_IMAGE_PRIMARY=true

# OpenRouter — site coder (primary: UI/UX Pro Max + OpenRouter on every APPROVE)
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_MAX_TURNS=12
OPENROUTER_TIMEOUT_SECONDS=180
SITE_CODER_ENABLED=true
UI_UX_PRO_MAX_ENABLED=true

# OpenCode CLI — optional fallback site generation
OPENCODE_ENABLED=false
OPENCODE_BIN=opencode
OPENCODE_MODEL=openrouter/anthropic/claude-sonnet-4
OPENCODE_AGENT=site-builder
OPENCODE_TIMEOUT_SECONDS=600
